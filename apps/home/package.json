{
  "name": "@contentco-op/home",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "prestart": "node scripts/verify-runtime-env.mjs && node scripts/verify-critical-media.mjs",
    "prebuild": "node scripts/verify-runtime-env.mjs --phase=build && node scripts/verify-critical-media.mjs --phase=build",
    "dev": "next dev -p 4100",
    "build": "next build --webpack",
    "start": "node scripts/prepare-standalone-runtime.mjs && HOSTNAME=${HOSTNAME:-0.0.0.0} PORT=${PORT:-4100} node .next/standalone/apps/home/server.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@contentco-op/brand": "0.1.0",
    "@contentco-op/identity-access": "0.1.0",
    "@contentco-op/types": "0.1.0",
    "@contentco-op/ui": "0.1.0",
    "@stripe/react-stripe-js": "^5.6.1",
    "@stripe/stripe-js": "^8.10.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "@tanstack/react-table": "^8.21.3",
    "leaflet": "^1.9.4",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.2",
    "eslint": "^9.39.0",
    "eslint-config-next": "16.1.6",
    "typescript": "^5.9.3"
  }
}
