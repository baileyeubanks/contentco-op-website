{
  "name": "contentco-op-monorepo",
  "version": "0.2.0",
  "private": true,
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:home": "npm run dev -w @contentco-op/home",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "ops:audit": "node scripts/run-cco-ops-audit.mjs --write",
    "ops:portfolio": "node scripts/validate-portfolio-manifest.mjs --write",
    "ops:routes": "node scripts/check-public-routes.mjs --write",
    "ops:intake": "node scripts/check-intake-readiness.mjs --write",
    "ops:drift": "node scripts/check-repo-drift.mjs --write",
    "verify:cco-nav": "node scripts/verify-cco-nav.mjs",
    "verify": "npm run verify:cco-nav"
  },
  "devDependencies": {
    "@types/node": "^20.19.16",
    "eslint": "^9.39.0",
    "turbo": "^2.5.6",
    "typescript": "^5.9.3"
  }
}
